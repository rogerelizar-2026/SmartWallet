```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.class
*.o
*.exe
*.dll
*.so
*.a
*.obj
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build artifacts
dist/
build/
target/

# Logs and temp files
*.log
*.tmp
*.swp

# Editors/IDE
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Gradle
.gradle/

# MyPy
.mypy_cache/

# Pytest
.pytest_cache/
```