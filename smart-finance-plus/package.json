{
  "name": "smart-finance-plus",
  "version": "2.0.0",
  "description": "Smart Finance+ - Versão modernizada e modular do Smart Finance",
  "type": "module",
  "main": "src/core/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\""
  },
  "keywords": [
    "finance",
    "personal-finance",
    "budget",
    "expense-tracker",
    "financial-management"
  ],
  "author": "Smart Finance Team",
  "license": "MIT",
  "devDependencies": {
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/smart-finance-plus/smart-finance-plus.git"
  },
  "bugs": {
    "url": "https://github.com/smart-finance-plus/smart-finance-plus/issues"
  },
  "homepage": "https://github.com/smart-finance-plus/smart-finance-plus#readme"
}
